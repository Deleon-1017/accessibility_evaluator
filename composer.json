{
    "name": "web-accessibility/web-accessibility-evaluator",
    "description": "WCAG 2.1 Accessibility Evaluation Tool",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Web Accessibility Team",
            "email": "team@web-accessibility-evaluator.example.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-dom": "*",
        "ext-libxml": "*",
        "guzzlehttp/guzzle": "^7.10",
        "masterminds/html5": "^2.7",
        "symfony/css-selector": "^7.4",
        "symfony/dom-crawler": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
