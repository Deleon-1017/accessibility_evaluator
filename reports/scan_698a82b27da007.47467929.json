            <?php endforeach; ?>\r\n                            <?php endif; ?>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n            \r\n            <!-- Preview Pane -->\r\n            <div class=\"col-lg-6 mb-4\">\r\n                <div class=\"card h-100\">\r\n                    <div class=\"card-header\">\r\n                        <h3 class=\"card-title h5 mb-0\">Page Preview<\/h3>\r\n                    <\/div>\r\n                    <div class=\"card-body\">\r\n                        <div id=\"previewContainer\">\r\n                            <?php if ($results['source_url']): ?>\r\n                                <iframe id=\"previewFrame\" \r\n                                        src=\"<?php echo htmlspecialchars($results['source_url']); ?>\" \r\n                                        frameborder=\"0\"\r\n                                        title=\"Website preview\"\r\n                                        data-preview=\"url\"><\/iframe>\r\n                            <?php else: ?>\r\n                                <iframe id=\"previewFrame\"\r\n                                        srcdoc=\"<?php echo htmlspecialchars($results['html_content'], ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8', false); ?>\"\r\n                                        sandbox=\"allow-same-origin\"\r\n                                        frameborder=\"0\"\r\n                                        title=\"HTML preview\"\r\n                                        data-preview=\"inline\"><\/iframe>\r\n                            <?php endif; ?>\r\n                        <\/div>\r\n                        <div class=\"mt-3\">\r\n                            <div class=\"alert alert-info small mb-0\">\r\n                                <i class=\"bi bi-info-circle me-2\"><\/i>\r\n                                Click on an issue to highlight the corresponding element in the preview (when available).\r\n                            <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n        <\/div>\r\n        \r\n        <!-- Detailed Report -->\r\n        <div class=\"row mt-4\">\r\n            <div class=\"col-12\">\r\n                <div class=\"card\">\r\n                    <div class=\"card-header\">\r\n                        <h3 class=\"card-title h5 mb-0\">Detailed Report<\/h3>\r\n                    <\/div>\r\n                    <div class=\"card-body\">\r\n                        <div class=\"table-responsive\">\r\n                            <table class=\"table table-hover\">\r\n                                <thead>\r\n                                    <tr>\r\n                                        <th>Type<\/th>\r\n                                        <th>WCAG<\/th>\r\n                                        <th>Principle<\/th>\r\n                                        <th>Issue<\/th>\r\n                                        <th>Recommendation<\/th>\r\n                                        <th>Severity<\/th>\r\n                                    <\/tr>\r\n                                <\/thead>\r\n                                <tbody>\r\n                                    <?php foreach ($results['issues'] as $issue): ?>\r\n                                    <tr>\r\n                                        <td>\r\n                                            <span class=\"badge bg-<?php \r\n                                                echo $issue['type'] === 'error' ? 'danger' : \r\n                                                     ($issue['type'] === 'warning' ? 'warning' : 'info'); \r\n                                            ?>\">\r\n                                                <?php echo ucfirst($issue['type']); ?>\r\n                                            <\/span>\r\n                                        <\/td>\r\n                                        <td><code><?php echo $issue['code']; ?><\/code><\/td>\r\n                                        <td>\r\n                                            <span class=\"badge bg-light text-dark\">\r\n                                                <?php echo $issue['principle']; ?>\r\n                                            <\/span>\r\n                                        <\/td>\r\n                                        <td><?php echo htmlspecialchars($issue['title']); ?><\/td>\r\n                                        <td class=\"small\"><?php echo htmlspecialchars($issue['recommendation']); ?><\/td>\r\n                                        <td>\r\n                                            <span class=\"badge severity-<?php echo $issue['severity']; ?>\">\r\n                                                <?php echo ucfirst($issue['severity']); ?>\r\n                                            <\/span>\r\n                                        <\/td>\r\n                                    <\/tr>\r\n                                    <?php endforeach; ?>\r\n                                <\/tbody>\r\n                            <\/table>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n        <\/div>\r\n        \r\n        <!-- Action Buttons -->\r\n        <div class=\"row mt-4 mb-5\">\r\n            <div class=\"col-12\">\r\n                <div class=\"d-flex justify-content-between\">\r\n                    <div>\r\n                        <a href=\"index.php\" class=\"btn btn-outline-secondary\">\r\n                            <i class=\"bi bi-arrow-left me-2\"><\/i>Back to Scanner\r\n                        <\/a>\r\n                    <\/div>\r\n                    <div>\r\n                        <button class=\"btn btn-outline-primary me-2\" onclick=\"window.print()\">\r\n                            <i class=\"bi bi-printer me-2\"><\/i>Print Report\r\n                        <\/button>\r\n                        <button class=\"btn btn-primary\" id=\"exportReport\">\r\n                            <i class=\"bi bi-download me-2\"><\/i>Export Results\r\n                        <\/button>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/main>\r\n    \r\n    <footer class=\"bg-white shadow-mt-auto\">\r\n        <div class=\"container py-5\">\r\n            <div class=\"row\">\r\n                <div class=\"col-md-4 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">About<\/h6>\r\n                    <p class=\"small text-muted\">Web Accessibility Evaluator helps you check your website's compliance with WCAG 2.1 guidelines. Get actionable insights to improve accessibility for all users.<\/p>\r\n                <\/div>\r\n                <div class=\"col-md-3 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">WCAG 2.1 Guidelines<\/h6>\r\n                    <ul class=\"list-unstyled small\">\r\n                        <li><a href=\"wcag.php?level=A\" class=\"text-decoration-none text-muted d-block mb-2\">Level A<\/a><\/li>\r\n                        <li><a href=\"wcag.php?level=AA\" class=\"text-decoration-none text-muted d-block mb-2\">Level AA<\/a><\/li>\r\n                        <li><a href=\"wcag.php?level=AAA\" class=\"text-decoration-none text-muted d-block mb-2\">Level AAA<\/a><\/li>\r\n                    <\/ul>\r\n                <\/div>\r\n                <div class=\"col-md-3 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">WCAG 2.1 Principles<\/h6>\r\n                    <ul class=\"list-unstyled small\">\r\n                        <li><a href=\"wcag.php?principle=Perceivable\" class=\"text-decoration-none text-muted d-block mb-2\">Perceivable<\/a><\/li>\r\n                        <li><a href=\"wcag.php?principle=Operable\" class=\"text-decoration-none text-muted d-block mb-2\">Operable<\/a><\/li>\r\n                        <li><a href=\"wcag.php?principle=Understandable\" class=\"text-decoration-none text-muted d-block mb-2\">Understandable<\/a><\/li>\r\n                        <li><a href=\"wcag.php?principle=Robust\" class=\"text-decoration-none text-muted d-block mb-2\">Robust<\/a><\/li>\r\n                    <\/ul>\r\n                <\/div>\r\n                <div class=\"col-md-2 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">Product<\/h6>\r\n                    <ul class=\"list-unstyled small\">\r\n                        <li><a href=\"index.php\" class=\"text-decoration-none text-muted d-block mb-2\">Scanner<\/a><\/li>\r\n                        <li><a href=\"wcag.html\" class=\"text-decoration-none text-muted d-block mb-2\">Guidelines<\/a><\/li>\r\n                    <\/ul>\r\n                <\/div>\r\n                <hr class=\"border-secondary-subtle\">\r\n                <div class=\"text-center\">\r\n                    <p class=\"small text-muted\">\r\n                        This tool is for educational purposes.\r\n                    <\/p>\r\n                    <p class=\"small text-muted mb-1\">\r\n                        Copyright &copy; <?php echo date('Y'); ?> All Rights Reserved.\r\n                    <\/p>\r\n                <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/footer>\r\n    \r\n    <script>\r\n    document.addEventListener('DOMContentLoaded', function() {\r\n        \/\/ Filter issues\r\n        document.querySelectorAll('.filter-issue').forEach(button => {\r\n            button.addEventListener('click', function() {\r\n                const filter = this.dataset.filter;\r\n                \r\n                \/\/ Update active button\r\n                document.querySelectorAll('.filter-issue').forEach(btn => {\r\n                    btn.classList.remove('active');\r\n                });\r\n                this.classList.add('active');\r\n                \r\n                \/\/ Filter issues\r\n                document.querySelectorAll('.issue-card').forEach(card => {\r\n                    if (filter === 'all') {\r\n                        card.style.display = 'block';\r\n                    } else {\r\n                        if (card.dataset.type === filter) {\r\n                            card.style.display = 'block';\r\n                        } else {\r\n                            card.style.display = 'none';\r\n                        }\r\n                    }\r\n                });\r\n            });\r\n        });\r\n        \r\n        \/\/ Highlight issue when clicked\r\n        document.querySelectorAll('.issue-card').forEach(card => {\r\n            card.addEventListener('click', function() {\r\n                \/\/ Remove active class from all cards\r\n                document.querySelectorAll('.issue-card').forEach(c => {\r\n                    c.classList.remove('active');\r\n                });\r\n                \r\n                \/\/ Add active class to clicked card\r\n                this.classList.add('active');\r\n                \r\n                \/\/ Scroll card into view\r\n                this.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\r\n                \r\n                \/\/ Try to highlight element in preview\r\n                const index = this.dataset.index;\r\n                highlightElement(index);\r\n            });\r\n        });\r\n        \r\n        \/\/ Export report\r\n        document.getElementById('exportReport').addEventListener('click', function() {\r\n            alert('Export feature would generate a PDF or JSON report in a full implementation.');\r\n        });\r\n        \r\n        function getInlinePreviewDocument() {\r\n            const previewFrame = document.getElementById('previewFrame');\r\n            if (!previewFrame || previewFrame.dataset.preview !== 'inline') {\r\n                return null;\r\n            }\r\n\r\n            try {\r\n                return previewFrame.contentDocument || previewFrame.contentWindow.document;\r\n            } catch (error) {\r\n                return null;\r\n            }\r\n        }\r\n\r\n        function ensureHighlightStyles(previewDoc) {\r\n            if (!previewDoc || previewDoc.getElementById('issue-highlight-style')) {\r\n                return;\r\n            }\r\n\r\n            const style = previewDoc.createElement('style');\r\n            style.id = 'issue-highlight-style';\r\n            style.textContent = '.highlight-element { outline: 3px solid #ff6b6b !important; background-color: rgba(255, 107, 107, 0.1) !important; transition: all 0.3s ease; }';\r\n            (previewDoc.head || previewDoc.documentElement).appendChild(style);\r\n        }\r\n\r\n        function highlightElement(index) {\r\n            const previewDoc = getInlinePreviewDocument();\r\n            if (!previewDoc || !previewDoc.body) {\r\n                return;\r\n            }\r\n\r\n            ensureHighlightStyles(previewDoc);\r\n\r\n            \/\/ Remove previous highlights\r\n            previewDoc.querySelectorAll('.highlight-element').forEach(el => {\r\n                el.classList.remove('highlight-element');\r\n            });\r\n            \r\n            \/\/ In a real implementation, you would have a mapping between\r\n            \/\/ issues and DOM elements. This is a simplified version.\r\n            const elements = previewDoc.body.querySelectorAll('*');\r\n            if (elements.length > index) {\r\n                elements[index].classList.add('highlight-element');\r\n                elements[index].scrollIntoView({ behavior: 'smooth', block: 'center' });\r\n            }\r\n        }\r\n        \r\n        \/\/ Initialize with first issue active if exists\r\n        const firstIssue = document.querySelector('.issue-card');\r\n        if (firstIssue) {\r\n            firstIssue.classList.add('active');\r\n        }\r\n    });\r\n    <\/script>\r\n<\/body>\r\n<\/html>",
