    "html_content": "<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>WCAG 2.1 Guidelines | Web Accessibility Evaluator<\/title>\r\n    <link href=\"https:\/\/cdn.jsdelivr.net\/npm\/bootstrap@5.3.8\/dist\/css\/bootstrap.min.css\" rel=\"stylesheet\" integrity=\"sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB\" crossorigin=\"anonymous\">\r\n    <script src=\"https:\/\/cdn.jsdelivr.net\/npm\/bootstrap@5.3.8\/dist\/js\/bootstrap.bundle.min.js\" integrity=\"sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK\/BmnVDxM+D2scQbITxI\" crossorigin=\"anonymous\"><\/script>\r\n    <link rel=\"stylesheet\" href=\"https:\/\/cdn.jsdelivr.net\/npm\/bootstrap-icons@1.11.3\/font\/bootstrap-icons.css\" \/>\r\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\r\n    <link rel=\"stylesheet\" href=\"style.css\">\r\n<\/head>\r\n<body>\r\n    <header>\r\n        <nav class=\"navbar navbar-expand-lg fixed-top\">\r\n            <div class=\"container-fluid\">\r\n                <a class=\"navbar-brand\" href=\"index.php\"><img src=\"logo.png\" alt=\"Logo\" width=\"60\" height=\"60\" class=\"mx-5 me-3\">Web Accessibility Evaluator<\/a>\r\n                <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"offcanvas\" data-bs-target=\"#offcanvasNavbar\" aria-controls=\"offcanvasNavbar\" aria-label=\"Toggle navigation\">\r\n                <span class=\"navbar-toggler-icon\"><\/span>\r\n                <\/button>\r\n                <div class=\"offcanvas offcanvas-end\" tabindex=\"-1\" id=\"offcanvasNavbar\" aria-labelledby=\"offcanvasNavbarLabel\">\r\n                    <div class=\"offcanvas-header\">\r\n                        <h5 class=\"offcanvas-title\" id=\"offcanvasNavbarLabel\">Web Accessibility Evaluator<\/h5>\r\n                        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"offcanvas\" aria-label=\"Close\"><\/button>\r\n                    <\/div>\r\n                    <div class=\"offcanvas-body\">\r\n                        <ul class=\"navbar-nav justify-content-end flex-grow-1 pe-3\">\r\n                            <li class=\"nav-item\">\r\n                                <a class=\"nav-link mx-lg-3\" aria-current=\"page\" href=\"index.php\">Home<\/a>\r\n                            <\/li>\r\n                            <li class=\"nav-item\">\r\n                                <a class=\"nav-link mx-lg-3 active\" href=\"wcag.html\">WCAG Guidelines<\/a>\r\n                            <\/li>\r\n                            <li class=\"nav-item\">\r\n                                <a class=\"nav-link mx-lg-3\" href=\"contact.html\">Contact<\/a>\r\n                            <\/li>\r\n                            <li class=\"nav-item\">\r\n                                <a class=\"nav-link mx-lg-3\" href=\"about.html\">About<\/a>\r\n                            <\/li>\r\n                        <\/ul>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n        <\/nav>\r\n    <\/header>\r\n    \r\n    <main class=\"pt-5 mt-5\">\r\n        <div class=\"container\">\r\n            <div class=\"row mb-5\">\r\n                <div class=\"col-lg-8\">\r\n                    <h1 class=\"mb-4\">WCAG 2.1 Guidelines<\/h1>\r\n                    <p class=\"my-5\">Web Content Accessibility Guidelines (WCAG) 2.1 defines how to make web content more accessible to people with disabilities. Accessibility involves a wide range of disabilities, including visual, auditory, physical, speech, cognitive, language, learning, and neurological disabilities.<\/p>\r\n                    <p>These guidelines are organized around four principles that lay the foundation for web accessibility: Perceivable, Operable, Understandable, and Robust.<\/p>\r\n                <\/div>\r\n                <div class=\"col-lg-4\">\r\n                    <div class=\"card border-0 shadow-sm mx-3\">\r\n                        <div class=\"card-body\">\r\n                            <h3 class=\"h5 mb-3\"><i class=\"bi bi-filter-circle me-2\"><\/i>Filter Guidelines<\/h3>\r\n                            <div class=\"mb-3\">\r\n                                <label for=\"levelFilter\" class=\"form-label fw-semibold\">Conformance Level<\/label>\r\n                                <select id=\"levelFilter\" class=\"form-select\">\r\n                                    <option value=\"all\">All Levels<\/option>\r\n                                    <option value=\"A\">Level A (Basic)<\/option>\r\n                                    <option value=\"AA\">Level AA (Recommended)<\/option>\r\n                                    <option value=\"AAA\">Level AAA (Advanced)<\/option>\r\n                                <\/select>\r\n                            <\/div>\r\n                            <div class=\"mb-3\">\r\n                                <label for=\"principleFilter\" class=\"form-label fw-semibold\">Principle<\/label>\r\n                                <select id=\"principleFilter\" class=\"form-select\">\r\n                                    <option value=\"all\">All Principles<\/option>\r\n                                    <option value=\"Perceivable\">Perceivable<\/option>\r\n                                    <option value=\"Operable\">Operable<\/option>\r\n                                    <option value=\"Understandable\">Understandable<\/option>\r\n                                    <option value=\"Robust\">Robust<\/option>\r\n                                <\/select>\r\n                            <\/div>\r\n                            <button id=\"resetFilters\" class=\"btn btn-outline-secondary w-100\">\r\n                                <i class=\"bi bi-arrow-clockwise me-2\"><\/i>Reset Filters\r\n                            <\/button>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n            \r\n            <div class=\"row mb-4\">\r\n                <div class=\"col-12\">\r\n                    <div class=\"alert alert-info d-flex align-items-center\" role=\"alert\">\r\n                        <i class=\"bi bi-info-circle-fill me-3 fs-4\"><\/i>\r\n                        <div>\r\n                            <strong>Showing <span id=\"resultCount\">0<\/span> guidelines<\/strong> based on your filter selection. Click on any guideline for more details.\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n            \r\n            <div class=\"table-responsive\">\r\n                <table class=\"table table-hover\" id=\"wcagTable\">\r\n                    <colgroup>\r\n                        <col class=\"col-principle\">\r\n                        <col class=\"col-level\">\r\n                        <col class=\"col-criteria\">\r\n                        <col class=\"col-description\">\r\n                        <col class=\"col-techniques\">\r\n                    <\/colgroup>\r\n                    <thead class=\"table-light\">\r\n                        <tr>\r\n                            <th scope=\"col\">Principle<\/th>\r\n                            <th scope=\"col\">Level<\/th>\r\n                            <th scope=\"col\">Success Criteria<\/th>\r\n                            <th scope=\"col\">Description<\/th>\r\n                            <th scope=\"col\">Techniques<\/th>\r\n                        <\/tr>\r\n                    <\/thead>\r\n                    <tbody id=\"wcagTableBody\">\r\n                        <!-- Table rows will be populated by JavaScript -->\r\n                    <\/tbody>\r\n                <\/table>\r\n            <\/div>\r\n            \r\n            <div class=\"row mt-5\">\r\n                <div class=\"col-12\">\r\n                    <div class=\"card border-0 bg-light\">\r\n                        <div class=\"card-body\">\r\n                            <h3 class=\"h5 mb-4\"><i class=\"bi bi-question-circle me-2\"><\/i>About Conformance Levels<\/h3>\r\n                            <div class=\"row g-3\">\r\n                                <div class=\"col-md-4\">\r\n                                    <div class=\"card h-100 border-0 shadow-sm\">\r\n                                        <div class=\"card-top perceivable\"><\/div>\r\n                                        <div class=\"card-body d-flex flex-column\">\r\n                                            <div class=\"d-flex align-items-center mb-3\">\r\n                                                <span class=\"level-badge level-A me-2\">Level A<\/span>\r\n                                                <span class=\"badge bg-primary rounded-pill ms-auto\">Basic<\/span>\r\n                                            <\/div>\r\n                                            <p class=\"card-text text-muted flex-grow-1 mb-0\">Basic requirements that must be satisfied. Essential for some users to be able to use web content.<\/p>\r\n                                        <\/div>\r\n                                        <div class=\"card-footer bg-white border-top-0 pt-0\">\r\n                                            <small class=\"text-muted\"><i class=\"bi bi-check-circle me-1\"><\/i>Required for all websites<\/small>\r\n                                        <\/div>\r\n                                    <\/div>\r\n                                <\/div>\r\n                                <div class=\"col-md-4\">\r\n                                    <div class=\"card h-100 border-0 shadow-sm\">\r\n                                        <div class=\"card-top operable\"><\/div>\r\n                                        <div class=\"card-body d-flex flex-column\">\r\n                                            <div class=\"d-flex align-items-center mb-3\">\r\n                                                <span class=\"level-badge level-AA me-2\">Level AA<\/span>\r\n                                                <span class=\"badge bg-success rounded-pill ms-auto\">Recommended<\/span>\r\n                                            <\/div>\r\n                                            <p class=\"card-text text-muted flex-grow-1 mb-0\">Addresses major barriers for disabled users. Required for most accessibility regulations and standards.<\/p>\r\n                                        <\/div>\r\n                                        <div class=\"card-footer bg-white border-top-0 pt-0\">\r\n                                            <small class=\"text-muted\"><i class=\"bi bi-star me-1\"><\/i>Target for most organizations<\/small>\r\n                                        <\/div>\r\n                                    <\/div>\r\n                                <\/div>\r\n                                <div class=\"col-md-4\">\r\n                                    <div class=\"card h-100 border-0 shadow-sm\">\r\n                                        <div class=\"card-top robust\"><\/div>\r\n                                        <div class=\"card-body d-flex flex-column\">\r\n                                            <div class=\"d-flex align-items-center mb-3\">\r\n                                                <span class=\"level-badge level-AAA me-2\">Level AAA<\/span>\r\n                                                <span class=\"badge bg-warning text-dark rounded-pill ms-auto\">Advanced<\/span>\r\n                                            <\/div>\r\n                                            <p class=\"card-text text-muted flex-grow-1 mb-0\">Enhanced accessibility features. The highest level of accessibility compliance, often used for specialized applications.<\/p>\r\n                                        <\/div>\r\n                                        <div class=\"card-footer bg-white border-top-0 pt-0\">\r\n                                            <small class=\"text-muted\"><i class=\"bi bi-award me-1\"><\/i>Enhanced accessibility<\/small>\r\n                                        <\/div>\r\n                                    <\/div>\r\n                                <\/div>\r\n                            <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/main>\r\n    \r\n    <footer class=\"bg-white shadow-mt-auto\">\r\n        <div class=\"container py-5\">\r\n            <div class=\"row\">\r\n                <div class=\"col-md-4 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">About<\/h6>\r\n                    <p class=\"small text-muted\">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Vitae impedit nesciunt, assumenda unde magni incidunt. Placeat commodi quod dolore, ex eligendi architecto velit ea dolores aliquam quis! Culpa, suscipit laudantium<\/p>\r\n                <\/div>\r\n                <div class=\"col-md-3 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">WCAG 2.1 Guidelines<\/h6>\r\n                    <ul class=\"list-unstyled small\">\r\n                        <li><a href=\"wcag.html?level=A\" class=\"text-decoration-none text-muted d-block mb-2\">Level A<\/a><\/li>\r\n                        <li><a href=\"wcag.html?level=AA\" class=\"text-decoration-none text-muted d-block mb-2\">Level AA<\/a><\/li>\r\n                        <li><a href=\"wcag.html?level=AAA\" class=\"text-decoration-none text-muted d-block mb-2\">Level AAA<\/a><\/li>\r\n                    <\/ul>\r\n                <\/div>\r\n                <div class=\"col-md-3 mb-4\">\r\n                    <h6 class=\"fw-bold text-uppercase mb-3\">WCAG 2.1 Principles<\/h6>\r\n                    <ul class=\"list-unstyled small\">\r\n                        <li><a href=\"wcag.html?princ