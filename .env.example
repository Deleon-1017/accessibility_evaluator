# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wcag_db
DB_USER=wcag_user
DB_PASSWORD=your_secure_password_here
DB_READER_USER=wcag_reader
DB_READER_PASSWORD=your_secure_reader_password_here
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Database Admin (for setup only)
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=your_admin_password_here

# API Configuration
API_BASE_URL=http://localhost/wcag/v1
API_RATE_LIMIT=100

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# JWT Configuration (for write operations)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=3600

# Environment
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug
